{
  "manifest_version": 3,
  "name": "Spectra",
  "version": "2.2",
  "description": "Analyzes website privacy, behavior, and phishing risks with live telemetry, external link scanning, and data collection tracking.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": "logo.png"
  },
  "icons": {
    "128": "logo.png"
  },
  "background": {
    "scripts": ["shield-domains.js", "background.js"]
  },
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["content.js"]
    }
  ],
  "commands": {
    "trigger-scan": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Scan current page with Spectra"
    }
  },
  "permissions": [
    "tabs",
    "storage",
    "webRequest",
    "declarativeNetRequest",
    "declarativeNetRequestFeedback"
  ],
  "host_permissions": [
    "*://*/*"
  ]
}
